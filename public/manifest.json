{
  "manifest_version": 3,
  "name": "VEO Automation 1.0.4",
  "version": "1.0.4",
  "description": "Automate batch generation on Google Flow AI.",
  "permissions": [
    "storage",
    "downloads",
    "tabs",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "https://labs.google/*"
  ],
  "action": {
    "default_popup": "index.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://labs.google/flow*"],
      "js": ["contentScript.js"]
    }
  ]
}
